{
  "name": "aether",
  "private": true,
  "version": "0.1.0",
  "description": "The Intelligence Behind Your Computer",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "dev:backend": "cd packages/backend && python -m uvicorn app.main:app --reload --port 8000",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build": "npm run build -w packages/frontend",
    "install:all": "npm install && cd packages/backend && pip install -r requirements.txt"
  },
  "workspaces": [
    "packages/frontend"
  ],
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
