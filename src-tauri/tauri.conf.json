{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AETHER",
  "version": "0.1.0",
  "identifier": "com.aether.os",
  "build": {
    "frontendDist": "../packages/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -w packages/frontend",
    "beforeBuildCommand": "npm run build -w packages/frontend"
  },
  "app": {
    "windows": [
      {
        "title": "AETHER",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
